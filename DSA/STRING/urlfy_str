#include <bits/stdc++.h>
using namespace std;

string URLify(string& s) {
    int n = s.length();
	
	string ans = "";
	for (int i = 0; i<n; i++) {
	    
	    // If " " is encountered, 
	    // append "%20" to string
		if (s[i] == ' ') {
		    ans.push_back('%');
		    ans.push_back('2');
		    ans.push_back('0');
		}
		
		// Else append the current 
		// character.
		else {
		    ans.push_back(s[i]);
		}
	}

	return ans;
}

int main() {
	string s = "i love programming";
	cout << URLify(s);
	return 0;
}