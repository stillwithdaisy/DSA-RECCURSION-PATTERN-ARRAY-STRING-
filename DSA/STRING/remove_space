#include <iostream>
#include <string>
using namespace std;

string removeSpaces(string s) {
    int n = s.length();
    int j = 0;  // write index

    for (int i = 0; i < n; i++) {
        if (s[i] != ' ') {
            s[j++] = s[i];
        }
    }

    return s.substr(0, j);
}

int main() {
    string s = "g  eeks   for ge  eeks  ";
    cout << removeSpaces(s);
    return 0;
}