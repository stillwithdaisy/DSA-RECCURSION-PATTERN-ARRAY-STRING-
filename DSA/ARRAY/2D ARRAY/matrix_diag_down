#include <iostream>
#include <vector>
using namespace std;

void diagonalTraversal(vector<vector<int>> &mat) {
    int n = mat.size();

    // Start from first row
    for (int col = 0; col < n; col++) {
        int i = 0, j = col;
        while (i < n && j >= 0) {
            cout << mat[i][j] << " ";
            i++; j--;
        }
    }

    // Start from last column (excluding first row)
    for (int row = 1; row < n; row++) {
        int i = row, j = n - 1;
        while (i < n && j >= 0) {
            cout << mat[i][j] << " ";
            i++; j--;
        }
    }
}

int main() {
    vector<vector<int>> mat = {
        {1, 2, 3},
        {4, 5, 6},
        {7, 8, 9}
    };

    diagonalTraversal(mat);
    return 0;
}