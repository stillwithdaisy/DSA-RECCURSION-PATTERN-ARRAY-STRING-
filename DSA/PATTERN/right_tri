#include<iostream>
using namespace std;

int main()
{

    int N = 5;

    // Outer loop runs N times, once for each row
    for (int i = 1; i <= N; i++) {
        // Inner loop prints 'i' stars
        for (int j = 1; j <= i; j++) {
            cout << "*";
        }

        cout << "\n";
    }

    return 0;
}