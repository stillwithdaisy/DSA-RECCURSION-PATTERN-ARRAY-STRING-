#include <iostream>
using namespace std;

//Driver Code Ends
void printPyramid(int n) {
    
    // Outer loop for rows
    for (int i = 1; i <= n; i++) {
        
        // Print spaces 
        for (int j = 1; j <= n - i; j++)
            cout << " ";
        
        // Print stars
        for (int j = 1; j <= 2 * i - 1; j++)
            cout << "*";
        
        cout << endl;
    }
}
//Driver Code Starts

int main() {
    int n = 5;
    printPyramid(n);
    return 0;
}
//Driver Code Ends