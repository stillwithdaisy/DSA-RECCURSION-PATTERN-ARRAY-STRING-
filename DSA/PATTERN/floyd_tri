#include<iostream>
using namespace std;

//Driver Code Ends
void printfloydtriangle(int n)
{
    int i, j, val = 1;
    for (i = 1; i <= n; i++)
    {
        for (j = 1; j <= i; j++)
            cout << val++ << " ";
        cout << endl;
    }
}
//Driver Code Starts

int main()
{
    printfloydtriangle(6);
    return 0;
}
//Driver Code Ends