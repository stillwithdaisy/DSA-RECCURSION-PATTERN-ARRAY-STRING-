#include<iostream>
using namespace std;

int main()
{
    int N = 5;

    // Outer loop runs N times, once for each row
    for (int i = 1; i <= N; i++) {
        // Inner loop prints 'i - 1' spaces
        for (int j = 1; j <= i - 1; j++) {
            cout << "  ";
        }

        // Inner loop prints 'N - i + 1' stars
        for (int j = 1; j <= N - i + 1; j++) {
            cout << "*";
        }
   
        cout << "\n";
    }

    return 0;
}