#include <iostream>
#include <cmath>
using namespace std;

bool armstrong(int n)
{  
    // converting to string
    string number = to_string(n);

    n = number.length();
    int output = 0;
    for (char i : number)
        output = output + (int)pow((i - '0'), n);
        
    // check if equal to number
    if (output == stoi(number))
        return true;
    else
        return false;
}

int main()
{   
    int n = 153;
    
     if(armstrong(n)){
        cout << "true";
    }else{
        cout << "false";
    }
}